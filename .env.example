# === LLM API Keys (Case A: external API mode) ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# === Deployment Mode ===
# "api" = Case A (external LLM API), "local" = Case B (local LLM only)
DEPLOYMENT_MODE=api

# === Local LLM (Case B) ===
LOCAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LOCAL_LLM_BASE_URL=http://localhost:8000/v1

# === Embedding Model ===
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# === Paths ===
DATA_DIR=./data
OUTPUT_DIR=./output
