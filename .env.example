# === LLM API Key ===
# Green Lens uses Groq's free-tier hosted LLM (llama-3.3-70b-versatile).
# Get a free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# === Setup ===
# 1. Copy this file:    cp .env.example .env
# 2. Edit .env and replace the placeholder with your real key
# 3. Start the backend — python-dotenv auto-loads .env on startup:
#      cd backend && uvicorn app:app --host 0.0.0.0 --port 8000
#
# .env is gitignored, so your real key never gets committed.
